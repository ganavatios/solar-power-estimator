<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
</head>
<body>
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100">
        <circle cx="50" cy="50" r="45" fill="#FFA500"/>
        <circle cx="50" cy="50" r="20" fill="#FFD700"/>
        <line x1="50" y1="5" x2="50" y2="25" stroke="#FFD700" stroke-width="3"/>
        <line x1="50" y1="75" x2="50" y2="95" stroke="#FFD700" stroke-width="3"/>
        <line x1="5" y1="50" x2="25" y2="50" stroke="#FFD700" stroke-width="3"/>
        <line x1="75" y1="50" x2="95" y2="50" stroke="#FFD700" stroke-width="3"/>
        <line x1="15" y1="15" x2="30" y2="30" stroke="#FFD700" stroke-width="3"/>
        <line x1="70" y1="70" x2="85" y2="85" stroke="#FFD700" stroke-width="3"/>
        <line x1="85" y1="15" x2="70" y2="30" stroke="#FFD700" stroke-width="3"/>
        <line x1="30" y1="70" x2="15" y2="85" stroke="#FFD700" stroke-width="3"/>
    </svg>
</body>
</html>
